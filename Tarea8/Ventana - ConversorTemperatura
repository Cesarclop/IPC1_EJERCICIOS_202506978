    private void jButtonKelvinActionPerformed(java.awt.event.ActionEvent evt) {                                              
        try {
            double celsius = Double.parseDouble(jTextFieldCelsius.getText().trim());
            double kelvin = celsius + 273.15;
            JOptionPane.showMessageDialog(this,String.format("Resultado: %.2f K", kelvin),"Conversión a Kelvin",JOptionPane.INFORMATION_MESSAGE);
        } catch (NumberFormatException e) {
            JOptionPane.showMessageDialog(this,"Ingrese un valor numerico valido.","Error de entrada",JOptionPane.ERROR_MESSAGE);
        }
    }                                             

    private void jButtonFahrenheitActionPerformed(java.awt.event.ActionEvent evt) {                                                  
        try {
            double celsius = Double.parseDouble(jTextFieldCelsius.getText().trim());
            double fahrenheit = celsius * 9.0 / 5.0 + 32;
            
            
            JOptionPane.showMessageDialog(this,String.format("Resultado: %.2f °F", fahrenheit),"Conversión a Fahrenheit",JOptionPane.INFORMATION_MESSAGE);
            
        } catch (NumberFormatException e) {
            JOptionPane.showMessageDialog(this,"Ingrese un valor numeico valido.","Error de entrada",JOptionPane.ERROR_MESSAGE);
        }
    }                                                 

    
